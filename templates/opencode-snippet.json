{
  "instructions": [
    "memory/SYSTEM_INVARIANTS.md",
    "memory/HANDOFF.md"
  ],
  "agent": {
    "gm": {
      "description": "Primary co-developer and orchestrator",
      "mode": "primary",
      "model": "opencode-go/qwen3.7-plus",
      "temperature": 0.2,
      "prompt": "{file:.opencode/prompts/gm.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": {
          "src/**": "allow",
          "AGENTS.md": "allow",
          "memory/HANDOFF.md": "allow",
          ".opencode/**/*.md": "allow",
          "*dist/*": "deny",
          "*node_modules/*": "deny",
          "*SYSTEM_INVARIANTS.md": "deny",
          "memory/learnings.jsonl": "deny"
        },
        "bash": {
          "python memory/filter.py *": "allow",
          "git status": "allow",
          "git diff": "allow",
          "git log": "allow",
          "git add *": "allow",
          "git commit *": "allow",
          "*": "ask"
        },
        "task": {
          "code-reviewer": "allow",
          "test-writer": "allow",
          "meta-agent": "allow",
          "fuzzer": "allow",
          "docs-writer": "allow",
          "security": "allow",
          "explorer": "allow",
          "refactorer": "allow",
          "*": "deny"
        },
        "webfetch": "allow"
      }
    },
    "code-reviewer": {
      "description": "Reviews code diffs against project rules. Structured report with severity-ranked findings. Read-only.",
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-pro",
      "temperature": 0.1,
      "steps": 10,
      "prompt": "{file:.opencode/prompts/code-reviewer.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "webfetch": "deny",
        "bash": {
          "git diff *": "allow",
          "git log *": "allow",
          "git status *": "allow",
          "python memory/filter.py *": "allow",
          "*": "deny"
        }
      }
    },
    "meta-agent": {
      "description": "Analyzes failure patterns from learnings, metrics, git history. Evolves other agents' prompts to eliminate recurring failures.",
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-pro",
      "temperature": 0.2,
      "steps": 15,
      "prompt": "{file:.opencode/prompts/meta-agent.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": {
          ".opencode/prompts/*.md": "allow",
          "AGENTS.md": "allow",
          "*": "deny"
        },
        "bash": {
          "git log *": "allow",
          "git diff *": "allow",
          "git status *": "allow",
          "python memory/filter.py *": "allow",
          "*": "ask"
        },
        "webfetch": "deny",
        "question": "allow"
      }
    },
    "fuzzer": {
      "description": "Adversarial tester — writes edge-case tests, runs them, reports failures. Never edits src/.",
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-pro",
      "temperature": 0.7,
      "steps": 15,
      "prompt": "{file:.opencode/prompts/fuzzer.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": {
          "tests/test_fuzz_*": "allow",
          "*": "deny"
        },
        "bash": {
          "python -m pytest tests/test_fuzz_*": "allow",
          "python memory/filter.py *": "allow",
          "*": "ask"
        },
        "webfetch": "deny"
      }
    },
    "docs-writer": {
      "description": "Keeps READMEs, API docs, and inline comments in sync with code changes. Only touches *.md files.",
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-pro",
      "temperature": 0.2,
      "steps": 10,
      "prompt": "{file:.opencode/prompts/docs-writer.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": {
          "**/*.md": "allow",
          "*": "deny"
        },
        "bash": {
          "python memory/filter.py *": "allow",
          "*": "ask"
        },
        "webfetch": "deny"
      }
    },
    "security": {
      "description": "Security auditor — hardcoded secrets, injection, missing auth, unsafe deserialization. Read-only.",
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-pro",
      "temperature": 0.1,
      "steps": 10,
      "prompt": "{file:.opencode/prompts/security.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "bash": {
          "git diff *": "allow",
          "python memory/filter.py *": "allow",
          "*": "deny"
        },
        "webfetch": "deny"
      }
    },
    "explorer": {
      "description": "Context gatherer — maps how a feature works across the codebase, returns focused summary. Read-only.",
      "mode": "subagent",
      "model": "opencode-go/qwen3.7-plus",
      "temperature": 0.1,
      "steps": 10,
      "prompt": "{file:.opencode/prompts/explorer.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "bash": {
          "python memory/filter.py *": "allow",
          "*": "deny"
        },
        "webfetch": "deny"
      }
    },
    "refactorer": {
      "description": "Structural changes (extract, rename, split) without changing behavior. Runs tests after each step.",
      "mode": "subagent",
      "model": "opencode-go/qwen3.7-plus",
      "temperature": 0.1,
      "steps": 15,
      "prompt": "{file:.opencode/prompts/refactorer.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": {
          "src/**": "allow",
          "*": "deny"
        },
        "bash": {
          "python -m pytest *": "allow",
          "python memory/filter.py *": "allow",
          "git diff *": "allow",
          "*": "ask"
        },
        "webfetch": "deny"
      }
    },
    "test-writer": {
      "description": "Scaffolds unit tests for pure functions, utilities, and isolated logic. Read source code, write tests only.",
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-pro",
      "temperature": 0.2,
      "steps": 10,
      "prompt": "{file:.opencode/prompts/test-writer.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": {
          "**/*.test.*": "allow",
          "**/*_test.*": "allow",
          "**/test_*.*": "allow",
          "*": "deny"
        },
        "webfetch": "deny",
        "bash": {
          "python memory/filter.py *": "allow",
          "*": "ask"
        }
      }
    }
  }
}
